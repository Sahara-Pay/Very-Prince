// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id // Unique identifier for the organization (Symbol on-chain)
  name        String   // Display name of the organization
  admin       String   // Primary administrator wallet address
  createdAt   DateTime @default(now()) // When the organization was first indexed
  updatedAt   DateTime @updatedAt // Last time the metadata was updated

  @@index([createdAt])
}

model Transaction {
  id            String   @default(cuid()) // Internal tracking ID
  txHash        String   // Stellar blockchain transaction hash
  eventIndex    Int      // Position of the event within the transaction
  walletAddress String   // Actor associated with the transaction
  volumeUSD     Decimal  // Value of the transaction in USD at the time of ledger closure
  createdAt     DateTime // Exact timestamp of ledger closure (Partition Key)
  type          String   // Type of event (e.g., "PAYOUT_ALLOCATED")
  ledger        Int      // Ledger sequence number
  rawData       String?  // Original JSON payload from the Soroban RPC

  @@id([id, createdAt])
  @@unique([txHash, eventIndex, createdAt]) // Ensures no duplicate events are indexed
  @@index([createdAt])
  @@index([walletAddress])
  @@index([txHash])
  @@index([ledger])
}

model PayoutEvent {
  id            String   @default(cuid()) // Internal tracking ID
  orgId         String   // Associated organization ID
  maintainer    String   // Recipient maintainer address
  amountStroops BigInt   // Payout amount in stroops (10^-7 XLM)
  amountXlm     Decimal  // Payout amount converted to XLM
  ledger        Int      // Ledger sequence number
  txHash        String   // Stellar transaction hash
  createdAt     DateTime // Timestamp of the payout (Partition Key)

  @@id([id, createdAt])
  @@index([orgId])
  @@index([maintainer])
  @@index([createdAt])
}

model Maintainer {
  address   String   @id
  orgId     String
  createdAt DateTime @default(now())

  @@index([orgId])
}

model IndexerState {
  id                  String   @id @default("default")
  lastProcessedLedger Int
  updatedAt           DateTime @updatedAt
}

model VerifiedContract {
  address    String   @id
  isVerified Boolean  @default(true)
  riskLevel  String   @default("LOW") // LOW, MEDIUM, HIGH
  createdAt  DateTime @default(now())

  @@index([address])
}

enum InvoiceStatus {
  ACTIVE      // Minted and currently active
  REPAID      // Fully repaid/settled
  CANCELLED   // Cancelled before repayment
  OVERDUE     // Past due date but not repaid
}

model Invoice {
  id           String        @id @default(cuid())
  invoiceId    String        @unique // On-chain invoice identifier
  faceValue    Decimal       // Value in stroops (smallest unit)
  faceValueUSD Decimal       // Value in USD (for stablecoin/oracle integration)
  status       InvoiceStatus @default(ACTIVE)
  issuer       String        // Wallet address of issuer
  holder       String?       // Current holder address (if transferred)
  dueDate      DateTime?     // Optional due date
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repaidAt     DateTime?     // When the invoice was repaid

  @@index([status])
  @@index([issuer])
  @@index([createdAt])
}

model WebhookConfig {
  id             String            @id @default(cuid())
  organizationId String            @unique
  url            String
  secret         String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deliveries     WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id              String        @id @default(cuid())
  webhookConfigId String
  webhookConfig   WebhookConfig @relation(fields: [webhookConfigId], references: [id])
  payload         String        // JSON string
  statusCode      Int?
  responseBody    String?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  @@index([webhookConfigId])
  @@index([createdAt])
}

model ApiKey {
  id             String   @id @default(cuid())
  organizationId String
  hashedKey      String   // SHA-256 hash of the API key for secure storage
  name           String?  // Optional display name for the key
  lastUsedAt     DateTime? // Track when the key was last used
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, hashedKey]) // Prevent duplicate keys for same org
  @@index([organizationId])
  @@index([isActive])
  @@index([createdAt])
}

model MaintainerNotification {
  walletAddress    String   @id
  email            String
  optIn            Boolean  @default(true)
  unsubscribeToken String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
