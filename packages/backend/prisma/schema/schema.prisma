// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  // Primary (writer) connection — migrations always use DATABASE_URL.
  // Read replicas are configured in src/services/db.ts via DATABASE_REPLICA_URL.
  url      = env("DATABASE_URL")
}